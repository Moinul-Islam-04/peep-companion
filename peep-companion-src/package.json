{
  "name": "peep-companion",
  "version": "1.0.0",
  "description": "Your productivity companion",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/generate-icon.js && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "node scripts/generate-icon.js && vite build && electron-builder",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "puppeteer-core": "^25.1.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "build": {
    "appId": "com.peep.companion",
    "productName": "Peep Companion",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}
